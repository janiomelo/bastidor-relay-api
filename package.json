{
  "name": "bastidor-relay-api",
  "version": "0.1.0",
  "description": "Relay API para Bastidor com identidade criptografica e sincronizacao",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node --loader tsx/cjs src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "docker:test": "docker build --target test -t bastidor-relay:test .",
    "test": "node --import tsx --test tests/e2e/saude.spec.ts",
    "test:e2e": "node --import tsx --test tests/e2e/saude.spec.ts",
    "test:watch": "node --import tsx --test --watch tests/e2e/saude.spec.ts",
    "lint": "eslint src tests",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.512.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "fastify": "^4.25.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
