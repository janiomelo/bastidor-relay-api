# Servidor
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Banco de Dados
DATABASE_URL=postgresql://usuario:senha@localhost:5432/bastidor_relay

# Storage: MinIO (desenvolvimento local — espelha Cloudflare R2 de producao)
# Em producao, as variaveis equivalentes apontam para R2
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=bastidor-storage
S3_REGION=us-east-1

# Saude
HEALTH_CHECK_TIMEOUT_MS=500
HEALTH_CACHE_TTL_SECONDS=5
